---
const { count = 3, size = "1.25rem", color = "var(--primary)", class: className } = Astro.props;
---

<div class:list={["flex justify-center items-center gap-2 opacity-40 my-6 select-none", className]} aria-hidden="true">
  {Array.from({ length: count }).map(() => (
    <svg width={size} height={size} viewBox="0 0 24 24" fill={color} xmlns="http://www.w3.org/2000/svg">
      <path d="M8.5 3.5c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zm7 0c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2zM5.5 8c-.83 0-1.5.67-1.5 1.5S4.67 11 5.5 11 7 10.33 7 9.5 6.33 8 5.5 8zm13 0c-.83 0-1.5.67-1.5 1.5s.67 1.5 1.5 1.5 1.5-.67 1.5-1.5S19.33 8 18.5 8zM12 10c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3zm0 7c-2.33 0-7 1.17-7 3.5V22h14v-1.5c0-2.33-4.67-3.5-7-3.5z"/>
    </svg>
  ))}
</div>
