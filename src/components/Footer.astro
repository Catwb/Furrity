---
import MarkdownIt from "markdown-it";
import { profileConfig, siteConfig } from "../config";
import { url } from "../utils/url-utils";

const currentYear = new Date().getFullYear();

const footerConfig = siteConfig.footer;
const footerLines = footerConfig?.content;
const hasCustomFooter = footerConfig?.enable && footerLines && footerLines.length > 0;
const md = new MarkdownIt({ html: true });
---

{hasCustomFooter
? <div class="card-base py-6 px-6 mt-8 mb-8 flex flex-col items-center justify-center markdown-footer">
    {footerLines!.map((line) => <p set:html={md.renderInline(line)} />)}
</div>
: <div class="card-base py-6 px-6 mt-8 mb-8 flex flex-col items-center justify-center">
    <div class="transition text-50 text-sm text-center">
        &copy; <span id="copyright-year">{currentYear}</span> {profileConfig.name}. All Rights Reserved. /
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href={url('rss.xml')}>RSS</a> /
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href={url('sitemap-index.xml')}>Sitemap</a><br>
        Powered by
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href="https://astro.build">Astro</a> &
        <a class="transition link text-[var(--primary)] font-medium" target="_blank" href="https://github.com/saicaca/fuwari">Fuwari</a>
    </div>
</div>
}

<style is:global>
    .markdown-footer a {
        @apply text-[var(--primary)] font-medium;
    }
    .markdown-footer p {
        @apply text-sm text-center;
    }
</style>
